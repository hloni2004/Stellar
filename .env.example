# Copy this file to .env and fill in values locally. Do NOT commit your real keys.

# Supabase
SUPABASE_URL=
# Use either SUPABASE_ANON_KEY (limited) or SUPABASE_SERVICE_ROLE_KEY / SUPABASE_SERVICE_KEY (server-only)
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_KEY=

# Escrow account secret (server-only). Keep this private.
ESCROW_SECRET=

# Stellar / Soroban
HORIZON_URL=
STELLAR_NETWORK=TESTNET
SOROBAN_CONTRACT_ID=
SOROBAN_RPC_URL=
